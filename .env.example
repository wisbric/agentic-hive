# Required — generate with: openssl rand -hex 32
OVERLAY_SESSION_SECRET=

# Optional — separate secret for SSH key encryption
# OVERLAY_ENCRYPTION_SECRET=

# Server
# OVERLAY_LISTEN=:8080
# OVERLAY_DB_PATH=/data/overlay.db
# OVERLAY_LOG_LEVEL=info

# Session polling (seconds)
# OVERLAY_POLL_INTERVAL=30

# Terminal idle timeout (seconds, 0=disabled)
# OVERLAY_TERMINAL_IDLE_TIMEOUT=0

# Login rate limiting
# OVERLAY_LOGIN_RATE_LIMIT=5
# OVERLAY_LOGIN_RATE_WINDOW=900

# OIDC (optional)
# OVERLAY_AUTH_MODE=oidc
# OVERLAY_OIDC_ISSUER_URL=https://keycloak.example.com/realms/myrealm
# OVERLAY_OIDC_CLIENT_ID=agentic-hive
# OVERLAY_OIDC_CLIENT_SECRET=
# OVERLAY_OIDC_REDIRECT_URL=https://hive.example.com/api/auth/oidc/callback
# OVERLAY_OIDC_ROLES_CLAIM=groups
# OVERLAY_OIDC_ADMIN_GROUP=hive-admin

# Vault / OpenBao (optional)
# OVERLAY_KEYSTORE_BACKEND=vault
# OVERLAY_VAULT_ADDR=https://vault.example.com
# OVERLAY_VAULT_TOKEN=
# OVERLAY_VAULT_SECRET_PATH=agentic-hive/ssh-keys

# Readiness probe
# OVERLAY_READYZ_REQUIRE_SERVER=false
